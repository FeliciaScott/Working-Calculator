<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ElevateU | Learn, Earn & Level Up</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', sans-serif;
    }

    body {
      background: #07111f;
      color: white;
      overflow-x: hidden;
      line-height: 1.6;
    }

    body::before {
      content: "";
      position: fixed;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(0,255,200,0.15), transparent 70%);
      top: -200px;
      right: -100px;
      z-index: -1;
    }

    body::after {
      content: "";
      position: fixed;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(119,0,255,0.2), transparent 70%);
      bottom: -200px;
      left: -100px;
      z-index: -1;
    }

    header {
      padding: 25px 7%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      background: rgba(7, 17, 31, 0.9);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      z-index: 100;
    }

    .logo {
      font-size: 1.8rem;
      font-weight: 800;
      color: #00ffc8;
      letter-spacing: 1px;
    }

    nav {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }

    nav a {
      text-decoration: none;
      color: #c8d6f0;
      font-size: 0.95rem;
      transition: 0.3s;
    }

    nav a:hover {
      color: #00ffc8;
    }

    .hero {
      min-height: 92vh;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      align-items: center;
      gap: 60px;
      padding: 80px 7%;
    }

    .hero-text h1 {
      font-size: 4rem;
      line-height: 1.05;
      margin-bottom: 20px;
    }

    .hero-text span {
      color: #00ffc8;
    }

    .hero-text p {
      color: #afbdd4;
      max-width: 620px;
      margin-bottom: 30px;
      font-size: 1.05rem;
    }

    .hero-buttons {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 14px 24px;
      border-radius: 14px;
      border: none;
      cursor: pointer;
      font-weight: 700;
      transition: 0.3s;
      text-decoration: none;
      display: inline-block;
    }

    .primary {
      background: linear-gradient(135deg, #00ffc8, #00b8ff);
      color: #07111f;
    }

    .secondary {
      background: rgba(255,255,255,0.08);
      color: white;
      border: 1px solid rgba(255,255,255,0.12);
    }

    .btn:hover {
      transform: translateY(-4px);
    }

    .hero-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 30px;
      padding: 30px;
      backdrop-filter: blur(10px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-top: 30px;
    }

    .stat-box {
      background: rgba(255,255,255,0.04);
      padding: 20px;
      border-radius: 18px;
    }

    .stat-box h2 {
      color: #00ffc8;
      font-size: 2rem;
    }

    section {
      padding: 90px 7%;
    }

    .section-title {
      font-size: 2.7rem;
      margin-bottom: 15px;
    }

    .section-subtitle {
      color: #9db0cf;
      max-width: 760px;
      margin-bottom: 45px;
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 25px;
    }

    .card {
      background: rgba(255,255,255,0.05);
      border-radius: 24px;
      padding: 28px;
      border: 1px solid rgba(255,255,255,0.08);
      transition: 0.3s;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      width: 150px;
      height: 150px;
      background: rgba(0,255,200,0.08);
      border-radius: 50%;
      top: -60px;
      right: -60px;
    }

    .card:hover {
      transform: translateY(-8px);
      border-color: rgba(0,255,200,0.3);
    }

    .card h3 {
      margin-bottom: 12px;
      font-size: 1.3rem;
    }

    .card p {
      color: #b8c4d8;
      font-size: 0.95rem;
    }

    .tag {
      display: inline-block;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(0,255,200,0.12);
      color: #00ffc8;
      font-size: 0.8rem;
      margin-bottom: 15px;
    }

    .financial-panel {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 30px;
      margin-top: 40px;
    }

    .money-box {
      background: linear-gradient(145deg, rgba(0,255,200,0.08), rgba(0,120,255,0.08));
      padding: 35px;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .money-box h3 {
      margin-bottom: 12px;
      font-size: 1.5rem;
    }

    .money-box ul {
      margin-top: 20px;
      padding-left: 20px;
      color: #c7d3e7;
    }

    .money-box li {
      margin-bottom: 12px;
    }

    .challenge-section {
      background: rgba(255,255,255,0.03);
      border-top: 1px solid rgba(255,255,255,0.05);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .challenge-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }

    .challenge-card {
      background: rgba(255,255,255,0.05);
      border-radius: 20px;
      padding: 24px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .challenge-card h4 {
      margin-bottom: 10px;
      color: #00ffc8;
    }

    .support-area {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px;
      margin-top: 40px;
    }

    .support-box {
      background: rgba(255,255,255,0.05);
      padding: 30px;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .support-box textarea,
    .support-box input {
      width: 100%;
      margin-top: 15px;
      padding: 15px;
      border-radius: 14px;
      border: none;
      background: rgba(255,255,255,0.08);
      color: white;
    }

    .support-box textarea {
      min-height: 130px;
      resize: vertical;
    }

    .support-box button {
      margin-top: 15px;
      width: 100%;
    }

    .response {
      margin-top: 18px;
      color: #00ffc8;
      font-weight: 600;
    }

    footer {
      padding: 50px 7%;
      text-align: center;
      color: #8ea1be;
    }

    @media(max-width: 768px) {
      .hero-text h1 {
        font-size: 2.8rem;
      }

      nav {
        display: none;
      }

      .section-title {
        font-size: 2.1rem;
      }
    }
  </style>
</head>
<body>

  <header>
    <div class="logo">ElevateU</div>

    <nav>
      <a href="#learn">Learn</a>
      <a href="#money">Money Skills</a>
      <a href="#challenges">Challenges</a>
      <a href="#support">Support</a>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-text">
      <h1>Educational Entertainment That Helps You <span>Level Up In Real Life</span></h1>

      <p>
        ElevateU mixes learning, motivation, money skills, and higher education support into one experience teens actually enjoy using. Explore challenges, unlock knowledge, build confidence, and discover pathways to scholarships, careers, side hustles, and long-term financial growth.
      </p>

      <div class="hero-buttons">
        <a href="#learn" class="btn primary">Start Exploring</a>
        <a href="#support" class="btn secondary">Get Support</a>
      </div>
    </div>

    <div class="hero-card">
      <h2>Daily Growth Dashboard</h2>
      <p style="margin-top: 12px; color:#b8c4d8;">
        Designed like a social app, but focused on building a smarter future.
      </p>

      <div class="stat-grid">
        <div class="stat-box">
          <h2>12</h2>
          <p>Career Paths Explored</p>
        </div>

        <div class="stat-box">
          <h2>$840</h2>
          <p>Virtual Budget Saved</p>
        </div>

        <div class="stat-box">
          <h2>38</h2>
          <p>Micro Lessons Completed</p>
        </div>

        <div class="stat-box">
          <h2>5</h2>
          <p>Scholarship Matches</p>
        </div>
      </div>
    </div>
  </section>

  <section id="learn">
    <h2 class="section-title">Learning That Feels Entertaining</h2>
    <p class="section-subtitle">
      Instead of boring lectures, ElevateU turns education into an interactive experience using storytelling, challenges, simulations, career discovery, and creative thinking.
    </p>

    <div class="card-grid">
      <div class="card">
        <div class="tag">Trending Skill</div>
        <h3>AI & Future Careers</h3>
        <p>
          Learn how artificial intelligence changes industries, what jobs are growing, and how teens can prepare before graduation.
        </p>
      </div>

      <div class="card">
        <div class="tag">Interactive</div>
        <h3>Money Decision Simulator</h3>
        <p>
          Test financial choices and see how habits affect savings, debt, opportunities, and long-term freedom.
        </p>
      </div>

      <div class="card">
        <div class="tag">Mindset</div>
        <h3>Confidence Training</h3>
        <p>
          Build communication skills, emotional intelligence, leadership, and networking strategies often ignored in school.
        </p>
      </div>

      <div class="card">
        <div class="tag">Creative Growth</div>
        <h3>Content Creation Lab</h3>
        <p>
          Explore video editing, branding, digital marketing, and ways creators earn income online ethically.
        </p>
      </div>
    </div>
  </section>

  <section id="money">
    <h2 class="section-title">Financial Elevation Hub</h2>
    <p class="section-subtitle">
      Many teens never learn how money systems work. This section helps users understand budgeting, career income, entrepreneurship, investing basics, and higher education planning.
    </p>

    <div class="financial-panel">
      <div class="money-box">
        <h3>Scholarship & College Support</h3>
        <p>
          Discover strategies for applying to scholarships, choosing affordable pathways, avoiding unnecessary debt, and preparing for admissions.
        </p>

        <ul>
          <li>Essay writing guidance</li>
          <li>Career-aligned degree planning</li>
          <li>Community college transfer strategies</li>
          <li>Financial aid preparation</li>
        </ul>
      </div>

      <div class="money-box">
        <h3>Income & Side Hustle Learning</h3>
        <p>
          Teens can explore realistic ways to earn online and offline while learning responsibility and long-term thinking.
        </p>

        <ul>
          <li>Freelancing basics</li>
          <li>Social media strategy</li>
          <li>Portfolio building</li>
          <li>Beginner entrepreneurship ideas</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="challenge-section" id="challenges">
    <h2 class="section-title">Daily Challenges & Rewards</h2>
    <p class="section-subtitle">
      Users gain points and unlock achievements for positive habits, learning consistency, and future-focused actions.
    </p>

    <div class="challenge-grid">
      <div class="challenge-card">
        <h4>7-Day Budget Challenge</h4>
        <p>Track spending decisions and discover where small choices create big changes.</p>
      </div>

      <div class="challenge-card">
        <h4>Future Career Match</h4>
        <p>Answer questions and discover careers connected to your personality and strengths.</p>
      </div>

      <div class="challenge-card">
        <h4>Speak With Confidence</h4>
        <p>Practice communication and leadership scenarios through role-playing exercises.</p>
      </div>

      <div class="challenge-card">
        <h4>Digital Skill Sprint</h4>
        <p>Learn one new modern skill every day for a month to expand future opportunities.</p>
      </div>
    </div>
  </section>

  <section id="support">
    <h2 class="section-title">Support & Encouragement</h2>
    <p class="section-subtitle">
      ElevateU also helps users mentally stay on track through motivational guidance, educational planning, and goal reflection.
    </p>

    <div class="support-area">
      <div class="support-box">
        <h3>Future Goal Planner</h3>
        <input type="text" id="goalInput" placeholder="Enter a future goal...">
        <button class="btn primary" onclick="saveGoal()">Save Goal</button>
        <div class="response" id="goalResponse"></div>
      </div>

      <div class="support-box">
        <h3>Motivation Journal</h3>
        <textarea id="journal" placeholder="Write what you're struggling with or what you're aiming for..."></textarea>
        <button class="btn primary" onclick="showSupport()">Receive Encouragement</button>
        <div class="response" id="supportResponse"></div>
      </div>
    </div>
  </section>

  <footer>
    <p>
      ElevateU • Education + Entertainment + Financial Growth • Designed to help teens build a stronger future.
    </p>
  </footer>

  <script>
    function saveGoal() {
      const goal = document.getElementById('goalInput').value;
      const response = document.getElementById('goalResponse');

      if(goal.trim() === '') {
        response.innerHTML = 'Enter a goal to begin your growth journey.';
      } else {
        response.innerHTML = `Goal saved: <strong>${goal}</strong>. Keep moving toward it step by step.`;
      }
    }

    function showSupport() {
      const text = document.getElementById('journal').value;
      const response = document.getElementById('supportResponse');

      if(text.trim() === '') {
        response.innerHTML = 'Write something first so the system can respond.';
      } else {
        response.innerHTML = 'Progress takes consistency. Small actions repeated over time can completely change your future. Keep learning, keep adapting, and keep building.';
      }
    }
  </script>

</body>
</html>
